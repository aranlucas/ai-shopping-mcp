            "text": "{\"schema\":{\"name\":\"leave-site-modal-collection\",\"version\":\"1.0.0\"},\"meta\":{\"name\":\"modals\",\"versionKey\":18},\"data\":{\"configurations\":[{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"heading\":\"Thanks for visiting\",\"body\":\"You are now leaving {banner}.com and going to a third-party site. The Kroger Co., and its subsidiaries and affiliates, are not affiliated with or responsible for the sweepstakes. \",\"primary\":\"Enter to Win\",\"secondary\":\"Keep Shopping Here\",\"urls\":[\"https://www.unileverworldcup26.com/?utm_source=Kroger&utm_medium=Digital&utm_campaign=CLP&utm_term=UL-FIFA\"]},\"meta\":{\"name\":\"danone-sweepstakes_2\",\"versionKey\":7}},{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"heading\":\"Shop Airtime Cards at our Gift Card Mall\",\"body\":\"You are now leaving kroger.com and going to our Gift Card Mall, which is hosted, maintained, and administered by Blackhawk Network, Inc. By making a purchase from the Gift Card Mall, you agree to Blackhawk's Terms of Service, and any information you provide during the checkout process will be subject to the Blackhawk Network Privacy Policy.\",\"primary\":\"Go to Gift Card Mall\",\"secondary\":\"Keep Shopping Here\",\"urls\":[\"https://giftcards.kroger.com/prepaid-phone-cards?icid=lob:kpfgift|plt:banner|tac:espot|pla:airtime-wireless-telecomm|con:top-offers:2x-fuel-points\"]},\"meta\":{\"name\":\"airtime-wireless-telecomm\",\"versionKey\":7}},{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"heading\":\"Enter to Win\",\"body\":\"You are now leaving Kroger.com and going to a third-party site. The Kroger Co., and its subsidiaries and affiliates, is not affiliated with or responsible for the sweepstake.\",\"secondary\":\"Keep Shopping Here\",\"primary\":\"Click to Enter the Sweepstakes\",\"urls\":[\"http://www.sddffreeviptrip.com\"]},\"meta\":{\"name\":\"danone-lollapalooza\",\"versionKey\":6}},{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"primary\":\"Go to Gift Card Mall\",\"secondary\":\"Keep shopping here\",\"body\":\"You are now leaving {banner.com} and going to our Gift Card Mall, which is hosted, maintained, and administered by Blackhawk Network, Inc. By making a purchase from the Gift Card Mall, you agree to Blackhawk's Terms of Service, and any information you provide during the checkout process will be subject to the Blackhawk Network Privacy Policy.\",\"heading\":\"Shop gift cards for every occasion at our Gift Card Mall\",\"urls\":[\"/gcexpmoreegift\",\"/giftcards\",\"/giftcardegiftespot\",\"/kpfgiftnewkrgaming\",\"/b/o/gift-cards\",\"/gcckoutquicknav\",\"/gcexpmoregiftcards\",\"/gcexpmorelocal\",\"/gcexpmoregaming\",\"/gcexpmorestorecards\",\"/gcexpmorehmnhbby\",\"/gcexpmoredining\",\"/giftcardsactivation\",\"/giftcardsckbalance\",\"/giftcardscheckout\",\"/shexpmoregcthrdpty\",\"/shexpmoregcb2b\",\"/shexpmoregcfrstpty\",\"/shexpmoregcol\",\"/shopboostegift\",\"/esshopboostegift\",\"/mwkshopboostegift\",\"/prshopboostegift\",\"/boostholidaygiftguide\",\"/kpfquizgcmdining\",\"/kpfquizgcmgaming\",\"/kpfquizgcmshopping\",\"/kpfquizgcmhome\",\"/kpfholiday1\",\"/kpfholiday2\",\"/giftCardOrderStatus\",\"giftcards.kroger.com\",\"giftcards.kroger.com/contact\",\"/giftcardsshopegiftfromany\",\"/giftcardsbulkespot\",\"/gcmblwtsshopall\",\"giftcards.kroger.com/shop-local\",\"giftcards.kroger.com/egift-cards\",\"giftcards.kroger.com/trending\",\"giftcards.kroger.com/visa-mastercard-gift-card\",\"giftcards.kroger.com/value/50-gift-cards\",\"giftcards.kroger.com/value/20-gift-cards\",\"giftcards.kroger.com/our-store-cards\",\"giftcards.kroger.com/check-my-balance\",\"giftcards.kroger.com/promotions\",\"giftcards.kroger.com/restaurants\",\"giftcards.kroger.com/home\",\"giftcards.kroger.com/gaming-gift-cards\",\"giftcards.kroger.com/category/boost\",\"/giftcardshero\",\"/giftcardshero4x\",\"/giftcardherolocal\",\"/gcrbnegift \",\"/gcrbnpickup\",\"/gcrbnpopular\",\"/gcrbnol\",\"/gcrbnunder50\",\"/gcrbnunder20\",\"/gcrbnstorecards\",\"/gcrbnactivatepickup\",\"/gcmhotoffers\",\"/gcrbnegift\"]},\"meta\":{\"name\":\"gift-card-mall\",\"versionKey\":23}},{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"urls\":[\"record.us-betssongroupaffiliates.com\"],\"body\":\"You are being redirected to betsafe.com. Betsafe.com is controlled and operated by Betsson U.S. Corp. (“Betsson”), a third-party sportsbook licensed by the State of Colorado Division of Gaming. Any information that you choose to share with Betsson (or that Betsson automatically collects through your use of its applications or website) will be controlled by Betsson and subject to its terms and conditions and privacy policy. {banner} does not assume any responsibility for third party websites or applications and all use is at your own risk.\",\"primary\":\"Go to Betsafe\",\"secondary\":\"Keep shopping here\",\"heading\":\"Join the fun of sports betting with a licensed sportsbook!\"},\"meta\":{\"name\":\"sports-betting\",\"versionKey\":1}},{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"primary\":\"Go to e-Rewards\",\"urls\":[\"https://www.e-rewards.com/en/signup?id=kf4v16njaufyoyv\"],\"body\":\"By clicking “Join Now”, you will be leaving the Kroger Family of Companies and going to a website not operated by us. You will be subject to the privacy policy and terms & conditions of the e-Rewards® website (not those of the Kroger Family of Companies)\",\"secondary\":\"Keep Shopping Here\",\"heading\":\"Share. Earn. Get Rewarded.\"},\"meta\":{\"name\":\"kpm-dynata-1\",\"versionKey\":16}},{\"schema\":{\"name\":\"leave-site-modal\",\"version\":\"1.0.0\"},\"data\":{\"heading\":\"Find and Compare Medicare Coverage Options in Your Area\",\"body\":\"You are now leaving our website and being directed to HealthCompare, an Allstate company. Any information shared on their site is subject to CMS’s terms and privacy.\",\"primary\":\"Go to HealthCompare\",\"secondary\":\"Keep Browsing Here\",\"urls\":[\"compare.healthcompare.com/kroger/web\",\"https://compare.healthcompare.com/kroger/web\"]},\"meta\":{\"name\":\"team-ifg-kroger-health\",\"versionKey\":11}},{\"schema\":{\"name\":\"leave-site-crossbanner-modal\",\"version\":\"1.0.0\"},\"data\":{\"secondaryButtonText\":\"Keep Shopping Here\",\"heading\":\"Redirecting You to {banner.com}\",\"bodyText\":{\"schema\":{\"name\":\"text\",\"version\":\"1.0.0\"},\"data\":{\"text\":\"<p>Continue your shopping experience at {banner.com}. You can use your account information to sign into the site.</p><p>Please note that cart prices, promotions and item availability may change. Check your cart for the most recent information.</p>\"},\"meta\":{\"name\":\"leave-site-cross-banner-modal/bodytext2\",\"versionKey\":2}},\"urls\":[\"www.putsomethingheretonotbreakleavesitemodal.com\"]},\"meta\":{\"name\":\"leave-site-cross-banner-modal\",\"versionKey\":2}}]}}"
