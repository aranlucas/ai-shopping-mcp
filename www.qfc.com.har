            "mimeType": "application/json",
            "text": "{\"schema\":{\"name\":\"stringtable\",\"version\":\"1.0.0\"},\"meta\":{\"name\":\"modality/fulfillment/text\",\"versionKey\":10},\"data\":{\"tooltip\":{\"arrowMessage\":\"Choose how you’d like to shop right here\",\"topMessage\":\"More ways to get it all!\",\"bodyMessage\":\"With so many convenient options, getting your groceries and bulky items has never been easier.\",\"cta\":\"Learn More\",\"pickupText\":\"Pickup\",\"shipText\":\"Ship\",\"deliveryText\":\"Delivery\",\"inStoreText\":\"In-Store\",\"listBannerArrowMessage\":\"Start by choosing how\\nyou're shopping today.\"},\"postalCodeSearch\":{\"headerMessage\":\"How are you shopping today?\",\"inputLabel\":\"Search by Postal Code\",\"buttonText\":\"Search\",\"userLocationLabel\":\"Search by location\",\"userLocationButton\":\"Use My Location\",\"usingLocationText\":\"Using Location\"},\"pickUpOption\":{\"timeline\":\"Pick up at the store, with your order brought right to your vehicle.\",\"lockerPickupTimeline\":\"Order online, pickup from our temperature-controlled lockers.\"},\"deliveryOption\":{\"timeline\":\"Upgrade to Express at checkout for the fastest same-day service.\"},\"krogerDeliveryOption\":{\"timeline\":\"Delivered by Kroger associates in refrigerated trucks. Freshness guaranteed.\",\"uft2023MobilePromoText\":{\"boldPrefix\":\"NEW:\",\"message\":\"You can now reserve a Kroger Delivery time before you start shopping!\"}},\"allDeliveryOption\":{\"timeline\":\"Upgrade to Express at checkout for the fastest same-day service.\"},\"shipOption\":{\"timeline\":\"More than what’s in-store, shipped to your door.\"},\"inStoreOption\":{\"bodyMessage\":\"Clip coupons and manage lists.\"},\"inStoreReservationMessage\":{\"bodyMessage\":\"As health and safety continue to be our priority, delays or limited inventory may occur.\"}}}"
          },
