et; padding-left:0 !important;margin-right:0 !important;\\\"\\n*/\\n\\n/* This hides the Title of the Overview tab */\\n#onetrust-consent-sdk #onetrust-pc-sdk h4{\\ndisplay:none;\\n}\\n\\n/* This hides the Title and toggle for the 2nd tab */\\n#onetrust-pc-sdk .ot-desc-cntr:nth-child(2) .ot-grp-hdr1{\\ndisplay:none;\\n}\\n\\n#onetrust-pc-sdk .ot-grp-desc a {\\n    font-weight: 700;\\n    color: #4471b7;\\n    text-decoration: none;\\n    background-color: transparent;\\n    border: 0;\\n    box-sizing: border-box;\\n    margin: 0;\\n    padding: 0;\\n}\\n\\n/* RETAINING, but these sliders are NOT USED for GENERIC in Kroger Banners because there are no eligible opt-out rights for the generic consumer to exercise */\\n\\n/* Constructors for Slider */\\n\\n/* Sider Status Label */\\n#onetrust-pc-sdk .ot-label-status {\\n    font-size: 1em;\\n    font-weight: bold;\\n    position: relative;\\n    top: 2px;\\n    display: none;\\n    padding-right: 5px;\\n    float: left;\\n}\\n\\n/* Slider Bar */\\n#onetrust-pc-sdk .ot-switch {\\n    FONT-WEIGHT: 100;\\n    position: relative;\\n    display: inline-block;\\n    width: 45px;\\n    height: 30px;\\n    margin-bottom: 0px;\\n}\\n\\n/*Slider Circle */\\n\\n#onetrust-pc-sdk .ot-switch-nob {\\n    position: absolute;\\n    cursor: pointer;\\n    top: 0;\\n    left: 0;\\n    right: 0;\\n    bottom: 0;\\n    background-color: #f2f1f1;\\n    border: none;\\n    transition: all .2s ease-in 0s;\\n    -moz-transition: all .2s ease-in 0s;\\n    -o-transition: all .2s ease-in 0s;\\n    -webkit-transition: all .2s ease-in 0s;\\n    border-radius: 45px;\\n}\\n\\n\\n#onetrust-pc-sdk .ot-switch-nob:before {\\n    position: absolute;\\n    content: \\\"\\\";\\n    height: 30px;\\n    width: 30px;\\n    bottom: 1px;\\n    background-color: #7d7d7d;\\n    -webkit-transition: .4s;\\n    border-radius: 100%;\\n    top: 0px;\\n    transition: .4s;\\n}\\n\\n/* Raises Opt-Out of Sale title to the top, adjusts Slider position */\\n/* Position the title and toggle: */\\n\\n#onetrust-pc-sdk .ot-grp-hdr1 {\\n    padding-left: unset;\\n    width: unset;\\n    padding-top: 2px;\\n\\tpadding-right: 2px;\\n    margin-bottom: unset;\\n    padding-bottom: unset;\\n    position: absolute;\\n\\tright:0;\\n}\\n\\n#onetrust-pc-sdk .ot-desc-cntr {\\n    position: relative;\\n}\\n\\n/* Enables dynamic generation of Banner Logo based on loaded banner so templates can be shared across banners without using Branding Override, which would require all templates have the same structure/number of tabs, etc. This custom code approach was created by Heather Harkins, produced in cooperation with the Web Core team for 2023 Implementation. */\\n\\n/* Hide Default OT Image */\\n#onetrust-pc-sdk .ot-pc-logo.ot-pc-logo img {\\ndisplay:none;\\n}\\n\\n/* Set params for Div of Logo Image */\\n#onetrust-pc-sdk .ot-pc-logo.ot-pc-logo {\\nbackground-size: contain;\\nbackground-repeat: no-repeat;\\n}\\n\\n/* Logos by Banner */\\nbody[data-banner=\\\"bakersplus\\\"]   #onetrust-pc-sdk .ot-pc-logo.ot-pc-logo {\\nbackground-image: url('https://www.kroger.com/content/v2/binary/image/bakers_svg_logo--freshcart_bakers_color_logo--bakers.svg');\\n}\\nbody[data-banner=\\\"citymarket\\\"]   #onetrust-pc-sdk .ot-pc-logo.ot-pc-logo {\\nbackground-image: url('https://www.kroger.com/content/v2/binary/image/citymarket_svg_logo--freshcart_citymarket_color_logo--citymarket.svg');\\n}\\nbody[data-banner=\\\"copps\\\"]   #onetrust-pc-sdk .ot-pc-logo.ot-pc-logo {\\nbackground-image: url('https://www.kroger.com/content/v2/binary/image/metromarket_svg_logo--freshcart_metromarket_color_logo--metromarket.svg');\\n}\\nbody[data-banner=\\\"dillons\\\"]   #onetrust-pc-sdk .ot-pc-logo.ot-pc-logo {\\nbackground-image: url('https://www.kroger.com/content/v2/binary/image/dillons_svg_logo--freshcart_dillons_color_logo--dillons.svg');\\n}\\nbody[data-banner=\\\"food4less\\\"]   #onetrust-pc-sdk .ot-pc-logo.ot-pc-logo {\\nbackground-image: url('https://www.kroger.com/content/v