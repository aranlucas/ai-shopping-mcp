            "text": "{\"schema\":{\"name\":\"keymessage_list\",\"version\":\"1.0.0\"},\"meta\":{\"name\":\"key-messages_washington_ent_11-22-25\",\"versionKey\":5},\"data\":{\"keyMessages\":[{\"schema\":{\"name\":\"keymessage\",\"version\":\"1.0.0\"},\"data\":{\"webRoutes\":[\"/d/beer-wine-liquor\",\"/search?query=beer%20&searchType=default_search\",\"/search?query=michelob%20ultra&searchType=default_search\",\"/search?query=wine&searchType=default_search\",\"/search?query=white%20claw%20&searchType=default_search\",\"/search?query=vodka&searchType=default_search\",\"/search?query=red%20wine&searchType=default_search\",\"/search?query=white%20wine&searchType=default_search\",\"/search?query=champagne%20&searchType=default_search\"],\"content\":[{\"schema\":{\"name\":\"keymessage_ui\",\"version\":\"1.0.0\"},\"data\":{\"headerTag\":\"span\",\"isExternalLink\":false,\"isInverseText\":false,\"header\":\"Any Pickup order with alcohol must also contain $25 worth of non-alcoholic items in the state of Washington.\",\"ctaText\":\"Learn More\",\"ctaUrl\":\"/i/terms/alcohol-sales\",\"backgroundColor\":\"#FED141\"},\"meta\":{\"name\":\"key-messages/washington-adult-bev_07-24\",\"versionKey\":2}}]},\"meta\":{\"name\":\"key-messages/washington-adult-bev_07-24\",\"versionKey\":2}},{\"schema\":{\"name\":\"keymessage\",\"version\":\"1.0.0\"},\"data\":{\"content\":[{\"schema\":{\"name\":\"keymessage_ui\",\"version\":\"1.0.0\"},\"data\":{\"headerTag\":\"span\",\"isExternalLink\":false,\"isInverseText\":false,\"header\":\"Any Pickup order with alcohol must also contain $25 worth of non-alcoholic items in the state of Washington.\",\"ctaText\":\"Learn More\",\"ctaUrl\":\"/i/terms/alcohol-sales\",\"backgroundColor\":\"#FED141\"},\"meta\":{\"name\":\"key-messages/washington-adult-bev_07-24\",\"versionKey\":2}}],\"webRoutes\":[\"/search?query=prosecco%20&searchType=default_search\",\"/search?query=champagne%20&searchType=default_search\",\"/search?query=coors%20lite%20&searchType=default_