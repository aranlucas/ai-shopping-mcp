            "text": "{\"schema\":{\"name\":\"page\",\"version\":\"1.0.0\"},\"meta\":{\"name\":\"pr/weekly-digital-deals_ent_01-04\",\"versionKey\":15},\"data\":{\"meta\":{\"description\":\"Save all week long on your favorite products with our weekly digital deals. Find out more about these deals now!\",\"title\":\"Weekly Digital Deals\"},\"content\":[{\"schema\":{\"name\":\"contentwrapper\",\"version\":\"1.0.0\"},\"data\":{\"hexValue\":\"#CB4D21\",\"middleAsset\":[{\"schema\":{\"name\":\"headersection\",\"version\":\"1.0.0\"},\"data\":{\"tag\":\"h2\",\"textSize\":\"XL\",\"textAlignment\":\"center\",\"headerText\":\"Your Featured Weekly Deals\",\"inverse\":true,\"subText\":\"Same Great Savings Online & In-Store\"},\"meta\":{\"name\":\"pr/weekly-digital-deals/headersection_your_featured_weekly_deals_12-14\",\"versionKey\":1}}]},\"meta\":{\"name\":\"pr/weekly-digital-deals/contentwrapper_hero_12-14\",\"versionKey\":1}},{\"schema\":{\"name\":\"headersection\",\"version\":\"1.0.0\"},\"data\":{\"tag\":\"h2\",\"textSize\":\"XL\",\"textAlignment\":\"left\",\"headerText\":\"Featured Savings\",\"subText\":\"We’ve got hot deals you don’t want to miss. Simply clip your coupons and use up to 5 times through 1/10/23. Enjoy the same great savings you’d get in-store. Be sure to check back 1/11/23 for even more great deals.\",\"linkText\":\"View All\",\"linkUrl\":\"/cl/coupons/?savings=WDD\"},\"meta\":{\"name\":\"pr/weekly-digital-deals/headersection_featured_savings_01-04_ent\",\"versionKey\":1}},{\"schema\":{\"name\":\"coupons\",\"version\":\"1.0.0\"},\"data\":{\"filters\":{\"specialSavings\":[\"WDD\",\"EFY\"]},\"mode\":\"carousel\",\"gridId\":\"Featured Savings\",\"hideShipMessage\":true},\"meta\":{\"name\":\"pr/weekly-digital-deals/coupons_featured_savings_11-02\",\"versionKey\":1}},{\"schema\":{\"name\":\"headersection\",\"version\":\"1.0.0\"},\"data\":{\"tag\":\"h2\",\"textSize\":\"XL\",\"textAlignment\":\"left\",\"headerText\":\"One Stop Click & Shop\",\"subText\":\"After you clip your coupon, you can easily add the item to your cart.\",\"linkText\":\"Shop All\",\"linkUrl\":\"/search?keyword=WDDShopAllProduct22131&query=WDDShopAllProduct22131&searchType=mktg%20attribute&monet=promo&fulfillment=all&pzn=relevance\"},\"meta\":{\"name\":\"pr/weekly-digital-deals/headersection_one-stop_01-04\",\"versionKey\":1}},{\"schema\":{\"name\":\"productlist\",\"version\":\"2.0.0\"},\"data\":{\"fulfillmentMethods\":\"PICKUP,DELIVERY,SHIP\",\"modalityType\":\"NONE\",\"monet\":\"PROMO\",\"pzn\":\"RELEVANCE\",\"mode\":\"carousel\",\"count\":20,\"feedType\":\"products\",\"title\":\"WDDShopAllProduct22131\",\"q\":\"WDDShopAllProduct22131\",\"toaTarget\":\"NONE\"},\"meta\":{\"name\":\"pr/weekly-digital-deals/productlist_one-stop_01-04\",\"versionKey\":1}},{\"schema\":{\"name\":\"headersection\",\"version\":\"1.0.0\"},\"data\":{\"tag\":\"h2\",\"textSize\":\"XL\",\"textAlignment\":\"left\",\"headerText\":\"Pickup & Delivery Savings\",\"linkUrl\":\"/savings/cl/coupons/?savings=CL&savings=NSK\",\"linkText\":\"View All\"},\"meta\":{\"name\":\"pr/weekly-digital-deals/headersection_pickup-delivery-savings\",\"versionKey\":1}},{\"schema\":{\"name\":\"coupons\",\"version\":\"1.0.0\"},\"data\":{\"hideShipMessage\":true,\"mode\":\"carousel\",\"gridId\":\"Pickup & Delivery Savings\",\"filters\":{\"specialSavings\":[\"CL\",\"NSK\"]}},\"meta\":{\"name\":\"pr/weekly-digital-deals/coupons_pickup-delivery-savings\",\"versionKey\":1}},{\"schema\":{\"name\":\"withboost\",\"version\":\"1.0.0\"},\"data\":{\"targetedContent\":[{\"membershipStatus\":\"non-member\",\"content\":[{\"schema\":{\"name\":\"espot\",\"version\":\"2.0.0\"},\"data\":{\"espotItems\":[{\"tag\":\"h2\",\"headerSize\":\"L\",\"textAlignment\":\"Bottom\",\"elevated\":false,\"isImpressionObserved\":false,\"isExternal\":false,\"omnitureText\":\"WDD_Boost\",\"altText\":\"Try Boost FREE for 30 Days† SAVE up to $1,000 per year with Boost FREE grocery delivery and 2X Fuel Points.*\",\"url\":\"/pr/boost\",\"imageSet\":{\