            "text": "{\"data\":{\"coupons\":[{\"addedToCard\":false,\"brand\":\"Other\",\"canBeAddedToCard\":true,\"canBeRemoved\":true,\"cashbackCashoutType\":\"\",\"categories\":[\"General\"],\"clickListCoupon\":true,\"displayDescription\":\"\",\"displayEndDate\":\"2026-01-14T04:59:59Z\",\"displayStartDate\":\"2025-11-04T05:00:00Z\",\"enabled\":\"Y\",\"expirationDate\":\"2026-01-14T04:59:59Z\",\"filterGroups\":[\"RGVwYXJ0bWVudHM=_R2VuZXJhbA==\",\"U3BlY2lhbCBTYXZpbmdz_Q0w=\"],\"id\":\"4142511\",\"isSharable\":false,\"imageUrl\":\"https://cdnws.softcoin.com/mediaCache/ecoupon_5740809.jpg\",\"krogerCouponNumber\":\"800000174029\",\"longDescription\":\"\",\"modalities\":[\"PICKUP\",\"DELIVERY\"],\"popularitySortRank\":7,\"projection\":\"coupons.compact\",\"redemptionsAllowed\":1,\"relevanceSortRank\":1,\"requirementDescription\":\"Valid now through January 13, 2026, when you spend $75 or more on pickup and delivery, where available. To be eligible for this coupon, coupon must be clipped and redeemed (i.e., order must be received via pickup or delivery order) by January 13, 2026, at 11:59pm PT. Not valid on in-store, or purchases from third-party sites or apps, such as Instacart or DoorDash. Cannot be shared, redeemable by original recipient only. Limit of one (1) offer per household. Order(s) that include alcohol, tobacco products, fuel, money orders, taxes, postage stamps, gift cards/certificates, lottery, promotional tickets, CRV, Prescriptions and guest or customer services/fees, or pickup or delivery fees do not qualify toward minimum purchase amount. May not be redeemable for cash or gift cards, is non-refundable and may not be applied toward previous purchases. Subject to change at any time. Times are not guaranteed and may vary by location. Other restrictions may apply. See coupon for details. \",\"requirementQuantity\":75,\"savings\":20,\"shortDescription\":\"$20 off Your First Pickup or Delivery Order of $75 or more \",\"specialSavings\":[{\"name\":\"CL\",\"description\":\"Pickup & Delivery Only\",\"displayName\":\"Pickup & Delivery Only\",\"displayOrder\":4,\"endDate\":\"2124-12-31T05:00:00Z\",\"startDate\":\"2017-04-16T04:00:00Z\"}],\"status\":\"unclipped\",\"title\":\"Save $20.00 When You Spend $75.00\",\"totalDownloads\":1394892,\"type\":\"STANDARD\",\"value\":20,\"flexRetailerCouponId\":\"\"},{\"addedToCard\":false,\"brand\":\"Viva\",\"canBeAddedToCard\":true,\"canBeRemoved\":true,\"cashbackCashoutType\":\"\",\"categories\":[\"Cleaning Products\",\"Natural & Organic\",\"Beauty\"],\"clickListCoupon\":true,\"displayDescription\":\"\",\"displayEndDate\":\"2026-01-07T04:59:59Z\",\"displayStartDate\":\"2025-12-17T05:00:00Z\",\"enabled\":\"Y\",\"expirationDate\":\"2026-01-14T04:59:59Z\",\"filterGroups\":[\"RGVwYXJ0bWVudHM=_Q2xlYW5pbmcgUHJvZHVjdHM=\",\"RGVwYXJ0bWVudHM=_QmVhdXR5\",\"RGVwYXJ0bWVudHM=_TmF0dXJhbCAmIE9yZ2FuaWM=\",\"U3BlY2lhbCBTYXZpbmdz_Q0w=\"],\"id\":\"4167520\",\"isSharable\":false,\"imageUrl\":\"https://cdnws.softcoin.com/mediaCache/ecoupon_5817019.jpg\",\"krogerCouponNumber\":\"800000183938\",\"longDescription\":\"\",\"modalities\":[\"DELIVERY\",\"PICKUP\"],\"popularitySortRank\":4,\"projection\":\"coupons.compact\",\"redemptionsAllowed\":1,\"relevanceSortRank\":2,\"requirementDescription\":\"When you spend $40 or more on select Cottonelle toilet paper, Kleenex tissue, Viva paper towels and Scott toilet paper on PICKUP OR DELIVERY ONLY. Download the coupon once from December 17 - January 6 only. Redeem the coupon once from December 17 - January 13. Offer valid when you select Pickup, Delivery or Express Delivery. Offer not valid on in-store or DeliveryNOW orders.\",\"requirementQuantity\":40,\"savings\":0,\"shortDescription\":\"Spend $40 Save $10 on Cottonelle, Kleenex, Viva, Scott PICKUP OR DELIVERY ONLY\",\"specialSavings\":[{\"name\":\"CL\",\"description\":\"Pickup & Delivery Only\",\"displayName\":\"Pickup & Delivery Only\",\"displayOrder\":4,\"endDate\":\"2124-12-31T05:00:00Z\",\"startDate\":\"2017-04-16T04:00:00Z\"}],\"status\":\"unclipped\",\"title\":\"Save $10.00 When You Spend $40.00\",\"totalDownloads\":537401,\"type\":\"STANDARD\",\"value\":10,\"flexRetailerCouponId\":\"\"},{\"addedToCard\":false,\"brand\":\"Scotch-Brite\",\"canBeAddedToCard\":true,\"canBeRemoved\":true,\"cashbackCashoutType\":\"\",\"categories\":[\"Cleaning Products\"],\"clickListCoupon\":true,\"displayDescription\":\"on Scotch-Brite PICKUP OR DELIVERY ONLY \",\"displayEndDate\":\"2026-01-07T04:59:59Z\",\"displayStartDate\":\"2025-12-10T05:00:00Z\",\"enabled\":\"Y\",\"expirationDate\":\"2026-01-07T04:59:59Z\",\"filterGroups\":[\"RGVwYXJ0bWVudHM=_Q2xlYW5pbmcgUHJvZHVjdHM=\",\"U3BlY2lhbCBTYXZpbmdz_Q0w=\",\"U3BlY2lhbCBTYXZpbmdz_RXhwaXJpbmcgU29vbg==\",\"U3BlY2lhbCBTYXZpbmdz_RXhwaXJpbmcgU29vbg==\"],\"id\":\"4168381\",\"isSharable\":false,\"imageUrl\":\"https://cdnws.softcoin.com/mediaCache/ecoupon_5819781.jpg\",\"krogerCouponNumber\":\"800000183933\",\"longDescription\":\"\",\"modalities\":[\"PICKUP\",\"DELIVERY\"],\"popularitySortRank\":5,\"projection\":\"coupons.compact\",\"redemptionsAllowed\":5,\"relevanceSortRank\":3,\"requirementDescription\":\"When you buy ONE Scotch-Brite sponge, dish wand, cleaning pad or pet lint roller (select participating items only) on PICKUP OR DELIVERY ONLY. Use up to 5 times in a single transaction, while supplies last. Download and redeem the coupon once from December 10 - January 6 only. Offer valid when you select Pickup, Delivery or Express Delivery. Offer not valid on in-store or DeliveryNOW orders.\",\"requirementQuantity\":1,\"savings\":0,\"shortDescription\":\"Save 20% on Scotch-Brite PICKUP OR DELIVERY ONLY\",\"specialSavings\":[{\"name\":\"CL\",\"description\":\"Pickup & Delivery Only\",\"displayName\":\"Pickup & Delivery Only\",\"displayOrder\":4,\"endDate\":\"2124-12-31T05:00:00Z\",\"startDate\":\"2017-04-16T04:00:00Z\"},{\"name\":\"Expiring Soon\",\"displayName\":\"Expiring Soon\",\"displayOrder\":1000,\"description\":\"Coupons nearing their expirat