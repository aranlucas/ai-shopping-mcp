{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    // The views import shared types from `src/`, which transitively pulls in
    // files referencing Cloudflare Worker globals (Env, KVNamespace). Include
    // the generated worker types so those resolve under this config too.
    "types": ["../worker-configuration.d.ts"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
