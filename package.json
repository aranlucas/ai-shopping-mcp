{
  "name": "ai-shopping-list-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "pnpm lint && pnpm build:views && tsc --noEmit",
    "build:views": "INPUT=mcp-app.html vite build",
    "watch": "NODE_ENV=development INPUT=mcp-app.html vite build --watch",
    "serve": "wrangler dev",
    "test": "vitest run",
    "deploy": "pnpm build:views && wrangler deploy",
    "dev": "NODE_ENV=development concurrently \"pnpm watch\" \"pnpm serve\"",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "generate:apis": "pnpm generate:cart && pnpm generate:location && pnpm generate:product && pnpm generate:identity",
    "generate:cart": "openapi-typescript kroger/cart.json -o src//services/kroger/cart.d.ts",
    "generate:location": "openapi-typescript kroger/location.json -o src/services/kroger/location.d.ts",
    "generate:product": "openapi-typescript kroger/product.json -o src/services/kroger/product.d.ts",
    "generate:identity": "openapi-typescript kroger/identity.json -o src/services/kroger/identity.d.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@mcp-ui/server": "^6.1.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/vite": "^4.3.1",
    "@toon-format/toon": "^2.3.0",
    "agents": "^0.16.2",
    "hono": "^4.12.26",
    "neverthrow": "^8.2.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint-plugin-perfectionist": "^5.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ws": "8.20.1"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern && pnpm lint:fix"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.8.0"
}
