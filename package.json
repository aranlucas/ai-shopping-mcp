{
  "name": "ai-shopping-list-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run lint && tsc --noEmit",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "lint": "biome check --fix",
    "generate:cart": "npx openapi-typescript kroger/cart.yaml -o src//services/kroger/cart.d.ts",
    "generate:location": "npx openapi-typescript kroger/location.yaml -o src/services/kroger/location.d.ts",
    "generate:product": "npx openapi-typescript kroger/product.yaml -o src/services/kroger/product.d.ts",
    "generate:identity": "npx openapi-typescript kroger/identity.yaml -o src/services/kroger/identity.d.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@mcp-ui/server": "^6.1.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "agents": "^0.7.6",
    "hono": "^4.12.8",
    "neverthrow": "^8.2.0",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.27.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  }
}
