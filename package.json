{
  "name": "ai-shopping-list-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "npm run lint && npm run build:views && tsc --noEmit",
    "build:views": "INPUT=mcp-app.html vite build",
    "watch": "NODE_ENV=development INPUT=mcp-app.html vite build --watch",
    "serve": "wrangler dev",
    "test": "vitest run",
    "deploy": "npm run build:views && wrangler deploy",
    "dev": "NODE_ENV=development concurrently \"npm run watch\" \"npm run serve\"",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "generate:apis": "npm run generate:cart && npm run generate:location && npm run generate:product && npm run generate:identity",
    "generate:cart": "npx openapi-typescript kroger/cart.yaml -o src//services/kroger/cart.d.ts",
    "generate:location": "npx openapi-typescript kroger/location.yaml -o src/services/kroger/location.d.ts",
    "generate:product": "npx openapi-typescript kroger/product.yaml -o src/services/kroger/product.d.ts",
    "generate:identity": "npx openapi-typescript kroger/identity.yaml -o src/services/kroger/identity.d.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.5.0",
    "@mcp-ui/server": "^6.1.0",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tailwindcss/vite": "^4.3.0",
    "agents": "^0.12.3",
    "hono": "^4.12.18",
    "neverthrow": "^8.2.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern && npm run lint:fix"
  }
}
